{
  "dashboard": {
    "id": null,
    "uid": "agent-deploy-metrics",
    "title": "Agent Deploy Metrics",
    "tags": ["agent-deploy", "mcp", "prometheus"],
    "timezone": "browser",
    "schemaVersion": 36,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "Request Rate (QPS)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(agent_deploy_requests_total[1m])) by (tool_name)",
            "legendFormat": "{{tool_name}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": { "drawStyle": "line", "lineInterpolation": "linear", "pointSize": 3 },
            "unit": "reqps",
            "min": 0
          },
          "overrides": []
        },
        "options": {
          "tooltip": { "mode": "multi" },
          "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
        }
      },
      {
        "id": 2,
        "title": "Request Latency (P50 / P95 / P99)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(agent_deploy_request_duration_seconds_bucket[1m])) by (le, tool_name))",
            "legendFormat": "P50 {{tool_name}}",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(agent_deploy_request_duration_seconds_bucket[1m])) by (le, tool_name))",
            "legendFormat": "P95 {{tool_name}}",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(agent_deploy_request_duration_seconds_bucket[1m])) by (le, tool_name))",
            "legendFormat": "P99 {{tool_name}}",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": { "drawStyle": "line", "lineInterpolation": "linear" },
            "unit": "s",
            "min": 0
          },
          "overrides": []
        },
        "options": {
          "tooltip": { "mode": "multi" },
          "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
        }
      },
      {
        "id": 3,
        "title": "Tool Call Heatmap",
        "type": "heatmap",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(increase(agent_deploy_tool_calls_total[1m])) by (tool_name, agent_name)",
            "legendFormat": "{{tool_name}} / {{agent_name}}",
            "refId": "A"
          }
        ],
        "dataFormat": "tsbuckets",
        "heatmap": {},
        "options": {
          "calculate": false,
          "yAxis": { "unit": "short" },
          "tooltip": { "show": true, "showHistogram": true }
        },
        "fieldConfig": {
          "defaults": { "custom": { "scaleDistribution": { "type": "linear" } } },
          "overrides": []
        }
      },
      {
        "id": 4,
        "title": "Agent Execution Success Rate",
        "type": "stat",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(agent_deploy_agent_executions_total{status=\"success\"}[5m])) / sum(rate(agent_deploy_agent_executions_total[5m]))",
            "legendFormat": "Success Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.8 },
                { "color": "green", "value": 0.95 }
              ]
            }
          },
          "overrides": []
        },
        "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "center" }
      },
      {
        "id": 5,
        "title": "Policy Violations",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "sum(rate(agent_deploy_policy_violations_total[1m])) by (policy_level, violation_type)",
            "legendFormat": "{{policy_level}} / {{violation_type}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": { "drawStyle": "bars", "lineInterpolation": "linear" },
            "unit": "short",
            "min": 0
          },
          "overrides": []
        },
        "options": {
          "tooltip": { "mode": "multi" },
          "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum"] }
        }
      },
      {
        "id": 6,
        "title": "Cache Hit Rate",
        "type": "stat",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "expr": "sum(rate(agent_deploy_cache_hits_total[5m])) / (sum(rate(agent_deploy_cache_hits_total[5m])) + sum(rate(agent_deploy_cache_misses_total[5m])))",
            "legendFormat": "Hit Rate",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 0.5 },
                { "color": "green", "value": 0.8 }
              ]
            }
          },
          "overrides": []
        },
        "options": { "graphMode": "area", "colorMode": "value", "justifyMode": "center" }
      },
      {
        "id": 7,
        "title": "Market API Call Status",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
        "targets": [
          {
            "expr": "sum(rate(agent_deploy_market_requests_total[1m])) by (method, endpoint, status)",
            "legendFormat": "{{method}} {{endpoint}} — {{status}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": { "drawStyle": "line", "lineInterpolation": "linear", "pointSize": 3 },
            "unit": "reqps",
            "min": 0
          },
          "overrides": []
        },
        "options": {
          "tooltip": { "mode": "multi" },
          "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "sum"] }
        }
      }
    ]
  },
  "overwrite": true
}
