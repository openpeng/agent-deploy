{
  "name": "@openpeng/agent-deploy",
  "version": "1.0.0",
  "description": "MCP server that auto-deploys agents to any AI coding tool — Node.js edition",
  "type": "module",
  "main": "dist/index.js",
  "bin": { "agent-deploy": "dist/index.js" },
  "files": ["dist", "tools-registry.yaml"],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  },
  "engines": { "node": ">=18" },
  "keywords": ["mcp", "agent", "deploy", "ai-tools", "pilotdeck"],
  "license": "MIT",
  "author": "Peng Xiao",
  "repository": "github:openpeng/agent-deploy"
}