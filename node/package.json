{
  "name": "@openpeng/agent-deploy",
  "version": "1.0.0",
  "description": "MCP server that auto-deploys agents to any AI coding tool — Node.js edition",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-deploy": "dist/cli.js"
  },
  "files": [
    "dist",
    "tools-registry.yaml"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/openai": "^1.4.7",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "form-data": "^4.0.5",
    "glob": "^13.0.6",
    "js-yaml": "^4.2.0",
    "openai": "^6.42.0",
    "semver": "^7.8.2",
    "tar": "^7.5.16"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.7.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "agent",
    "deploy",
    "ai-tools",
    "pilotdeck"
  ],
  "license": "MIT",
  "author": "Peng Xiao",
  "repository": "github:openpeng/agent-deploy"
}
